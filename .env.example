# API key with Drive API enabled (folder must be "Anyone with the link can view")
GOOGLE_DRIVE_API_KEY=""
# Live sync: site auto-refreshes from Drive every MEDIA_REVALIDATE_SECONDS (default 120)
MEDIA_LIVE_SYNC="1"
MEDIA_REVALIDATE_SECONDS="120"
# Vercel Cron auth for /api/cron/media-sync (set in Vercel dashboard)
